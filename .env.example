# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — do not commit it.

# ── Firebase ────────────────────────────────────────────────────────────────
# Firebase console → Project settings → Your apps → SDK setup and configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
# Optional — only if you use Firebase Analytics
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── App ─────────────────────────────────────────────────────────────────────
# Firebase console → Authentication → your account → User UID
# Must match the UID in firestore.rules (isOwner function).
EXPO_PUBLIC_APP_OWNER_UID=your_firebase_auth_uid

# Google Cloud console → Credentials → Web client (OAuth 2.0)
# Or the "Web client" auto-created when Google sign-in is enabled in Firebase.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789012-xxxxxxxx.apps.googleusercontent.com
